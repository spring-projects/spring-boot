<?xml version="1.0" encoding="UTF-8"?>
<!-- tag::caches[] -->
<project>
	<build>
		<plugins>
			<plugin>
				<groupId>org.springframework.boot</groupId>
				<artifactId>spring-boot-maven-plugin</artifactId>
				<configuration>
					<image>
						<buildCache>
							<image>
								<name>docker.io/library/${project.artifactId}:build</name>
							</image>
						</buildCache>
					</image>
				</configuration>
			</plugin>
		</plugins>
	</build>
</project>
<!-- end::caches[] -->