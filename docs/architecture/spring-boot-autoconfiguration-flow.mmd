    style H fill:#9C27B0,color:white
    style L fill:#F44336,color:white
    style L1 fill:#E91E63,color:white
    style L2 fill:#E91E63,color:white
    style L3 fill:#E91E63,color:white
    style M fill:#FF5722,color:white
    style O fill:#009688,color:white
    style U fill:#4CAF50,color:white
    style S fill:#757575,color:white
